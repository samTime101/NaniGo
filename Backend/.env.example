PORT=8000
HOST=0.0.0.0

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# AI question generation (optional).
# Leave GEMINI_API_KEY empty to use the built-in offline fallback generator.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Voice tutor (ElevenLabs Conversational AI). Optional — leave empty to disable.
# Create an agent at https://elevenlabs.io/app/agents and enable overrides for
# "System prompt" and "First message" in the agent's Security settings.
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# Optional voice-answer ("speak" question) settings. Defaults work out of the
# box; override only to change the question-reading voice or models.
# ELEVENLABS_TTS_VOICE_ID=cjVigY5qzO86Huf0OWal
# ELEVENLABS_TTS_MODEL_ID=eleven_multilingual_v2
# ELEVENLABS_STT_MODEL_ID=scribe_v1

# Hearts refill timer (minutes)
HEART_REFILL_MINUTES=5

# SQLite database file
DATABASE_PATH=nanigo.db
